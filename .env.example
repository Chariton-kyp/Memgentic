# Memgentic Configuration
# Copy to .env and fill in your values

# --- Storage ---
# MEMGENTIC_DATA_DIR=~/.memgentic/data
# MEMGENTIC_STORAGE_BACKEND=local          # 'local' (file-based Qdrant) or 'qdrant' (server)
# MEMGENTIC_QDRANT_URL=http://localhost:6333
# MEMGENTIC_QDRANT_API_KEY=                # For Qdrant Cloud

# --- Embeddings ---
# MEMGENTIC_EMBEDDING_PROVIDER=ollama      # 'ollama' (local, free) or 'openai'
# MEMGENTIC_OLLAMA_URL=http://localhost:11434
# MEMGENTIC_OPENAI_API_KEY=               # Only if using OpenAI embeddings
#
# Embedding model — run `memgentic setup` to choose interactively, or set manually:
#
#   Default (balanced, ~800MB VRAM, runs on any discrete GPU):
MEMGENTIC_EMBEDDING_MODEL=qwen3-embedding:0.6b
MEMGENTIC_EMBEDDING_DIMENSIONS=768
#
#   Alternatives:
#     qwen3-embedding:4b     — Best quality, needs 4GB+ VRAM (2.5GB download)
#     qwen3-embedding:8b     — Top quality, needs 8GB+ VRAM (5GB download)
#     embeddinggemma:300m    — Google, lightweight, ~500MB VRAM (622MB download)
#     nomic-embed-text       — Compact, ~300MB VRAM, English-focused (274MB download)
#     (custom)               — Any Ollama-compatible embedding model

# --- Performance ---
# MEMGENTIC_EMBEDDING_BATCH_SIZE=8         # Concurrent embedding requests (lower for CPU)
# MEMGENTIC_IMPORT_CONCURRENCY=4           # Files processed in parallel during import

# --- LLM (for summarization, Phase 2) ---
# MEMGENTIC_SUMMARIZATION_MODEL=gemini-2.0-flash-lite
MEMGENTIC_GOOGLE_API_KEY=

# --- Daemon ---
# MEMGENTIC_WATCH_INTERVAL=30             # Seconds between file checks
# MEMGENTIC_IDLE_THRESHOLD=300            # Seconds of inactivity = conversation done

# --- API Authentication ---
# MEMGENTIC_API_KEY=                        # Optional: set to require API key on REST endpoints

# --- MCP Server ---
# MEMGENTIC_MCP_TRANSPORT=stdio            # 'stdio' (local) or 'streamable_http' (remote)
# MEMGENTIC_MCP_PORT=8200
